# Copy to `.env` for local dev, or set in Cloudflare Pages > Settings > Environment variables.
#
# Canonical site URL. Leave unset in production to use the default
# (https://kmwellnesscenter.com). On Cloudflare preview/branch deploys, set this
# to your *.pages.dev URL so canonicals/sitemap are correct AND the SEO component
# automatically emits <meta name="robots" content="noindex"> for non-production hosts.
PUBLIC_SITE_URL=https://kmwellnesscenter.com

# --- Lead / contact form (Cloudflare Pages Function at functions/api/lead.ts) ---
# These power the lead-capture forms. Set them in Cloudflare Pages > Settings >
# Environment variables (mark RESEND_API_KEY as a Secret). They are NOT used at
# build time, so they don't need to be in .env for local `astro build`.
#
# 1. Create a Resend account, add & verify the kmwellnesscenter.com domain
#    (add the DKIM/SPF DNS records Resend gives you), then create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where leads are delivered:
LEAD_TO_EMAIL=info@kmwellnesscenter.com
# Verified Resend sender (must be on a domain you verified in Resend):
LEAD_FROM_EMAIL=KM Wellness Website <leads@kmwellnesscenter.com>
