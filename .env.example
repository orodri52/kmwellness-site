# Copy to `.env` for local dev, or set in Cloudflare Pages > Settings > Environment variables.
#
# Canonical site URL. Leave unset in production to use the default
# (https://kmwellnesscenter.com). On Cloudflare preview/branch deploys, set this
# to your *.pages.dev URL so canonicals/sitemap are correct AND the SEO component
# automatically emits <meta name="robots" content="noindex"> for non-production hosts.
PUBLIC_SITE_URL=https://kmwellnesscenter.com
