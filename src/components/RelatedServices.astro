---
// Internal-linking mesh for the service (spoke) pages. Renders links to sibling
// services + back to the services hub, so Google sees a connected topic cluster
// instead of siloed pages. `current` is the page's own href (excluded from list).
import { services } from '../config/site';

interface Props {
  current: string;
  heading?: string;
}
const { current, heading = 'Explore related services' } = Astro.props;

const related = services.filter((s) => s.href !== current);
---
<nav class="related-services" aria-label="Related services">
  <h2>{heading}</h2>
  <ul>
    {related.map((s) => (
      <li><a href={s.href}>{s.name}</a></li>
    ))}
  </ul>
  <p class="related-hub"><a href="/services/">← Back to all services</a></p>
</nav>

<style>
  .related-services {
    margin: 3rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, currentColor 15%, transparent);
  }
  .related-services h2 {
    font-size: 1.1rem;
    margin: 0 0 0.75rem;
  }
  .related-services ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.4rem 1.25rem;
  }
  .related-services li a {
    display: inline-block;
    padding: 0.15rem 0;
  }
  .related-hub {
    margin-top: 1rem;
    font-weight: 600;
  }
</style>
