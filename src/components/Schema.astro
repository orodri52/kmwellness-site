---
// Site-wide JSON-LD structured data, emitted on every page.
// Includes Organization/MedicalBusiness (with NAP, hours, geo, sameAs) and
// WebSite. Per-page schema (FAQPage, Article) is added separately via FaqSchema
// / page-level <script type="application/ld+json"> blocks.
import { business } from '../config/site';

const site = Astro.site?.href.replace(/\/$/, '') ?? '';

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['MedicalBusiness', 'HealthAndBeautyBusiness', 'LocalBusiness'],
      '@id': `${site}/#organization`,
      name: business.name,
      legalName: business.legalName,
      url: `${site}/`,
      telephone: business.phoneRaw,
      email: business.email,
      image: `${site}/images/og-default.jpg`,
      logo: `${site}/images/logo.png`,
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: business.address.street,
        addressLocality: business.address.locality,
        addressRegion: business.address.region,
        postalCode: business.address.postalCode,
        addressCountry: business.address.country,
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: business.geo.latitude,
        longitude: business.geo.longitude,
      },
      openingHours: business.hours,
      areaServed: { '@type': 'City', name: 'El Paso' },
      sameAs: [business.social.facebook, business.social.instagram],
    },
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      url: `${site}/`,
      name: business.legalName,
      publisher: { '@id': `${site}/#organization` },
      inLanguage: 'en-US',
    },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
