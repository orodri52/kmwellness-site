---
import { business, nav } from '../config/site';
---
<header class="site-header">
  <div class="utility-bar" aria-label="Clinic contact details">
    <a href={`tel:${business.phoneRaw}`}>{business.phone}</a>
    <span>{business.hoursHuman}</span>
    <a href={`mailto:${business.email}`}>{business.email}</a>
  </div>

  <div class="nav-shell">
    <a class="brand-mark" href="/" rel="home" aria-label={`${business.name} home`}>
      <img class="brand-logo" src="/images/logo.png" alt="" width="736" height="370" decoding="async" />
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li class:list={[{'has-children': 'children' in item && item.children}]}>
            <a href={item.href}>{item.label}</a>
            {'children' in item && item.children && (
              <>
                <button
                  type="button"
                  class="submenu-toggle"
                  aria-expanded="false"
                  aria-label={`Toggle ${item.label} submenu`}
                >
                  <span aria-hidden="true"></span>
                </button>
                <ul>
                  {item.children.map((child) => (
                    <li><a href={child.href}>{child.label}</a></li>
                  ))}
                </ul>
              </>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <a class="button button-dark nav-cta" href="/contact-us/">Book a Consult</a>
  </div>
</header>

<script>
  document.querySelectorAll<HTMLLIElement>('.primary-nav .has-children').forEach((item) => {
    const toggle = item.querySelector<HTMLButtonElement>(':scope > .submenu-toggle');
    if (!toggle) return;
    toggle.addEventListener('click', () => {
      const isOpen = item.classList.toggle('submenu-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });
</script>
