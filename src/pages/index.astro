---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import { business } from '../config/site';
import danielGymPortrait from '../assets/images/daniel-gym-portrait.webp';
import medicalNutritionPhoto from '../assets/images/service-medical-nutrition.png';
import mealPrepPhoto from '../assets/images/service-meal-prep.png';
import personalTrainingPhoto from '../assets/images/service-personal-training.png';
import weightLossPhoto from '../assets/images/service-weight-loss.png';

const seo = {
  title: 'Weight Loss Clinic El Paso | KM Wellness Center',
  description:
    'A trusted weight loss clinic in El Paso. KM Wellness offers personalized nutrition, fitness training, and holistic weight management.',
  type: 'website' as const,
};

const principles = [
  {
    title: 'Evidence-based guidance',
    text: 'Nutrition and weight-loss plans grounded in current research and clinical standards.',
  },
  {
    title: 'Personalized plans',
    text: 'Nutrition, movement, and lifestyle strategies built around your body and goals.',
  },
  {
    title: 'Weight management',
    text: 'Sustainable approaches to help you reach and maintain a healthy weight.',
  },
  {
    title: 'Compassionate care',
    text: 'A supportive, judgment-free space to help you create lasting change.',
  },
];

const services = [
  {
    title: 'Medical Nutrition Therapy',
    href: '/services/medical-nutrition-therapy-and-nutrition-counseling/',
    text: 'Personalized nutrition for lasting wellness.',
    alt: 'Salmon bowl with grains and green vegetables',
    image: medicalNutritionPhoto,
    icon: 'leaf',
  },
  {
    title: 'Weight Loss Prescription',
    href: '/services/weight-loss-prescription-disease-management/',
    text: 'Medically supervised weight loss programs.',
    alt: 'Medical syringe on a neutral surface',
    image: weightLossPhoto,
    icon: 'clipboard',
  },
  {
    title: 'Exercise Classes & Personal Training',
    href: '/services/exercise-classes-and-personal-training/',
    text: 'Move better, get stronger, feel your best.',
    alt: 'Yoga mat, dumbbells, and water bottle',
    image: personalTrainingPhoto,
    icon: 'dumbbell',
  },
  {
    title: 'Meal Prep Services',
    href: '/services/additional-services/',
    text: 'Healthy, convenient meals made simple.',
    alt: 'Prepared chicken and vegetable meal bowl',
    image: mealPrepPhoto,
    icon: 'bowl',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Connect',
    text: 'Tell us about your goals.',
  },
  {
    number: '02',
    title: 'Personalized Plan',
    text: 'We create a plan tailored to you.',
  },
  {
    number: '03',
    title: 'Ongoing Support',
    text: 'We support you every step of the way.',
  },
  {
    number: '04',
    title: 'Lasting Results',
    text: 'Build habits that last a lifetime.',
  },
];

const supportItems = [
  'Insurance accepted',
  'Virtual & in-person appointments',
  'Registered dietitians',
  'Judgment-free support',
  'Flexible plans for real life',
];
---
<BaseLayout {...seo}>
  <div class="home-page">
    <section class="hero-panel" aria-labelledby="home-title">
      <div class="hero-art">
        <Image
          src={danielGymPortrait}
          alt="Daniel Chavez, RD, LD, CSCS, CISSN, co-founder and lead dietitian at KM Wellness Center in El Paso"
          widths={[500, 800, 1200]}
          sizes="(min-width: 900px) 500px, 100vw"
          format="webp"
          quality={75}
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="hero-copy">
        <p class="eyebrow">Holistic Weight Loss Clinic in El Paso</p>
        <h1 id="home-title">Personalized nutrition counseling <em>that fits your life.</em></h1>
        <p>
          Evidence-based guidance to help you improve your health, build sustainable habits, and
          feel your best.
        </p>
        <div class="hero-actions">
          <a class="button button-dark" href="/contact-us/">Book your consultation</a>
          <a class="text-link" href="/services/">View services</a>
        </div>
      </div>

      <div class="hero-trust" aria-label="Clinic highlights">
        <p>
          <span class="trust-icon trust-icon-shield" aria-hidden="true"></span>
          <strong>15+</strong>
          <span>Years of experience</span>
        </p>
        <p>
          <span class="trust-icon trust-icon-people" aria-hidden="true"></span>
          <strong>1000+</strong>
          <span>Happy clients</span>
        </p>
        <p>
          <span class="trust-icon trust-icon-award" aria-hidden="true"></span>
          <strong>Best of El Paso<br />2024 &amp; 2025</strong>
          <span>Local recognition</span>
        </p>
      </div>
    </section>

    <section class="principles-section" aria-labelledby="principles-title">
      <div class="principles-heading">
        <p class="eyebrow">Our approach</p>
        <h2 id="principles-title">Nutrition care that goes beyond the food on your plate.</h2>
        <p>
          We take a functional and evidence-based approach to help you reach your goals and feel
          your best.
        </p>
        <a class="button button-outline" href="/about-us/">Learn more about our approach</a>
      </div>
      <div class="principle-grid">
        {principles.map((item, index) => (
          <article>
            <span class={`principle-icon principle-icon-${index + 1}`} aria-hidden="true"></span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="home-detail-grid" aria-label="What to expect from KM Wellness">
      <figure class="quote-card">
        <blockquote>
          <p>The best diets don’t feel like diets. They feel like you.</p>
        </blockquote>
        <figcaption>KM Wellness</figcaption>
      </figure>

      <div class="expect-card">
        <h2>What to expect</h2>
        <div class="expect-steps">
          {processSteps.map((step) => (
            <article>
              <span>{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="ready-card">
        <div class="ready-image" aria-hidden="true"></div>
        <div>
          <h2>Ready to take the next step?</h2>
          <p>Book your consultation and let’s create a plan that works for you.</p>
          <a class="button button-dark" href="/contact-us/">Book now</a>
        </div>
      </div>
    </section>

    <section class="support-strip" aria-label="Patient support highlights">
      {supportItems.map((item, index) => (
        <p>
          <span class={`support-icon support-icon-${index + 1}`} aria-hidden="true"></span>
          <span>{item}</span>
        </p>
      ))}
    </section>

    <section class="content-section intro-section" aria-labelledby="journey-title">
      <div>
        <p class="eyebrow">KM Wellness Center is now open and taking new patients</p>
        <h2 id="journey-title">Embark on a journey with our wellness pros.</h2>
      </div>
      <div>
        <p>
          At KM Wellness Center, our mission is to help the El Paso community achieve sustainable
          health through our holistic weight loss clinic and personalized weight management programs.
          We combine nutrition counseling, medical nutrition therapy, fitness training, and
          lifestyle-based weight loss solutions to address the root causes of weight gain and
          metabolic challenges.
        </p>
        <a class="text-link" href="/about-us/">More about us</a>
      </div>
    </section>

    <section class="content-section services-section" aria-labelledby="services-title">
      <div class="section-heading">
        <p class="eyebrow">Our services</p>
        <h2 id="services-title">Comprehensive weight loss and nutrition care.</h2>
        <p>
          From private nutrition counseling to supervised weight-loss programs and fitness coaching,
          we provide a supportive environment to help you reach your goals.
        </p>
      </div>

      <div class="service-grid">
        {services.map((service, index) => (
          <article class:list={['service-card', `service-card-${index + 1}`]}>
            <div class="service-media">
              <Image
                src={service.image}
                alt={service.alt}
                widths={[280, 420, 560]}
                sizes="(min-width: 981px) 240px, 248px"
                format="webp"
                quality={82}
                loading="lazy"
                decoding="async"
              />
              <span class="service-icon" aria-hidden="true">
                {service.icon === 'leaf' && (
                  <svg viewBox="0 0 32 32" focusable="false">
                    <path d="M16 26V11" />
                    <path d="M16 18c-5.2-.3-8.7-3.6-9.7-8.8 4.9-.7 9.2 1.5 10.8 6.2" />
                    <path d="M16.5 17.8c4.9-.4 8.4-3.7 9.4-8.8-4.7-.7-8.8 1.3-10.5 5.8" />
                    <path d="M16 25c-2.1-3-4.1-4.8-7.8-5.4" />
                  </svg>
                )}
                {service.icon === 'clipboard' && (
                  <svg viewBox="0 0 32 32" focusable="false">
                    <path d="M11 8.5H8.8A2.8 2.8 0 0 0 6 11.3v12.9A2.8 2.8 0 0 0 8.8 27h14.4a2.8 2.8 0 0 0 2.8-2.8V11.3a2.8 2.8 0 0 0-2.8-2.8H21" />
                    <path d="M12 11h8V7.8A2.8 2.8 0 0 0 17.2 5h-2.4A2.8 2.8 0 0 0 12 7.8V11Z" />
                    <path d="M11 17h10" />
                    <path d="M11 22h7" />
                  </svg>
                )}
                {service.icon === 'dumbbell' && (
                  <svg viewBox="0 0 32 32" focusable="false">
                    <path d="M8 12v8" />
                    <path d="M5 14v4" />
                    <path d="M24 12v8" />
                    <path d="M27 14v4" />
                    <path d="M8 16h16" />
                    <path d="M12 11v10" />
                    <path d="M20 11v10" />
                  </svg>
                )}
                {service.icon === 'bowl' && (
                  <svg viewBox="0 0 32 32" focusable="false">
                    <path d="M8 15.5h16c0 5-3.3 9.5-8 9.5s-8-4.5-8-9.5Z" />
                    <path d="M11 26h10" />
                    <path d="M11 11c-1.5-1.5-1.5-3.2 0-5" />
                    <path d="M16 11c-1.5-1.5-1.5-3.2 0-5" />
                    <path d="M21 11c-1.5-1.5-1.5-3.2 0-5" />
                  </svg>
                )}
              </span>
            </div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
            <a class="service-arrow" href={service.href} aria-label={`Read more about ${service.title}`}>→</a>
          </article>
        ))}
      </div>
    </section>

    <section class="proof-section" aria-labelledby="proof-title">
      <div>
        <p class="eyebrow">Why choose us</p>
        <h2 id="proof-title">A weight-loss clinic built for sustainable change.</h2>
      </div>
      <ul>
        <li>Holistic weight loss center focused on sustainable results</li>
        <li>Personalized weight loss programs tailored to your lifestyle</li>
        <li>Experienced nutritionists and registered dietitians</li>
        <li>Medical nutrition therapy for metabolic and chronic conditions</li>
        <li>Fitness coaching and personal training support</li>
        <li>{business.awards} Award Winner</li>
      </ul>
      <div class="stats-card" aria-label="Clinic experience and client count">
        <p><strong>15+</strong><span>Years of experience</span></p>
        <p><strong>1000+</strong><span>Happy clients</span></p>
      </div>
    </section>

    <ReviewsSection solidBlackTabs reviewLimit={10} />

    <section class="booking-strip" aria-label="Schedule consultation">
      <div>
        <p class="eyebrow">Insurance accepted.</p>
        <p>We accept most PPO insurance plans.</p>
      </div>
      <div>
        <p class="eyebrow">Ready to get started?</p>
        <p>Book your consultation today.</p>
      </div>
      <a class="button button-dark" href="/contact-us/">Book now</a>
    </section>

    <LeadForm source="homepage" />
  </div>
</BaseLayout>
