---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import { business } from '../config/site';

const seo = {
  title: 'El Paso Wellness Center | Contact Us | KM Wellness Center',
  description:
    "Get in touch with KM Wellness Center—El Paso's trusted choice for nutrition, weight loss, and fitness programs tailored to your goals.",
  image: '/images/contact-og.jpg',
};
const a = business.address;
const fullAddress = `${a.street}, ${a.locality}, ${a.region} ${a.postalCode}`;
const mapsEmbedSrc = `https://maps.google.com/maps?q=${encodeURIComponent(fullAddress)}&t=m&z=14&output=embed&iwloc=near`;
---
<BaseLayout {...seo}>
  <Breadcrumbs crumbs={[{ name: 'Home', href: '/' }, { name: 'Contact Us', href: '/contact-us/' }]} />
  <h1>Contact Us</h1>

  <section>
    <h2>Have Anything To Ask? We're Always Ready.</h2>
    <p>
      At KM Wellness Center, our mission is to help the El Paso community live healthier, happier, and
      more fulfilling lives. We are committed to providing comprehensive wellness solutions that focus
      on nutrition, personal training, and medically guided weight loss support. As a proud winner of
      the Best of El Paso 2024 &amp; 2025, we are honored to continue making a positive impact in our
      community.
    </p>
  </section>

  <div class="contact-columns">
    <div class="contact-details-card">
      <h2>Contact Details</h2>
      <address>
        <strong>Phone:</strong> <a href={`tel:${business.phoneRaw}`}>{business.phone}</a><br />
        <strong>Email:</strong> <a href={`mailto:${business.email}`}>{business.email}</a><br />
        <strong>Address:</strong> {a.street}, {a.locality}, {a.region} {a.postalCode}<br />
        <a href={business.mapsUrl} rel="noopener" target="_blank">View on Google Maps</a>
      </address>

      <div class="contact-map">
        <iframe
          src={mapsEmbedSrc}
          width="100%"
          height="260"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Map showing ${business.name} at ${fullAddress}`}
        ></iframe>
      </div>
    </div>

    <div class="contact-form-card">
      <h2>Send Us a Message</h2>
      <ContactForm action="/api/lead" />
    </div>
  </div>
</BaseLayout>

<style>
  .contact-columns {
    display: grid;
    grid-template-columns: minmax(260px, 380px) 1fr;
    align-items: start;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .contact-details-card,
  .contact-form-card {
    padding: clamp(1.65rem, 3.5vw, 2.5rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: 0 16px 44px rgb(0 0 0 / 8%);
  }

  .contact-details-card {
    background: #e7e7e7;
  }

  .contact-form-card {
    background: #f2f2f2;
  }

  .contact-details-card h2,
  .contact-form-card h2 {
    margin-bottom: 1rem;
    font-size: clamp(1.9rem, 3.2vw, 3rem);
  }

  .contact-details-card > :last-child,
  .contact-form-card > :last-child {
    margin-bottom: 0;
  }

  .contact-details-card a:not(.button) {
    font-weight: 800;
  }

  @media (max-width: 860px) {
    .contact-columns {
      grid-template-columns: 1fr;
    }
  }

  .contact-map {
    margin-top: 1.25rem;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  .contact-map iframe {
    display: block;
  }
</style>
