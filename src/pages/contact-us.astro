---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import { business } from '../config/site';

const seo = {
  title: 'El Paso Wellness Center | Contact Us | Kingsway Wellness Center',
  description:
    "Get in touch with KM Wellness Center—El Paso's trusted choice for nutrition, weight loss, and fitness programs tailored to your goals.",
  image: '/images/contact-og.jpg',
};
const a = business.address;
---
<BaseLayout {...seo}>
  <Breadcrumbs crumbs={[{ name: 'Home', href: '/' }, { name: 'Contact Us', href: '/contact-us/' }]} />
  <h1>Contact Us</h1>

  <section>
    <h2>Have Anything To Ask? We're Always Ready.</h2>
    <p>
      At KM Wellness Center, our mission is to help the El Paso community live healthier, happier, and
      more fulfilling lives. We are committed to providing comprehensive wellness solutions that focus
      on nutrition, personal training, and medically guided weight loss support. As a proud winner of
      the Best of El Paso 2024 &amp; 2025, we are honored to continue making a positive impact in our
      community.
    </p>
  </section>

  <section>
    <h2>Contact Details</h2>
    <address>
      <strong>Phone:</strong> <a href={`tel:${business.phoneRaw}`}>{business.phone}</a><br />
      <strong>Email:</strong> <a href={`mailto:${business.email}`}>{business.email}</a><br />
      <strong>Address:</strong> {a.street}, {a.locality}, {a.region} {a.postalCode}<br />
      <a href={business.mapsUrl} rel="noopener" target="_blank">View on Google Maps</a>
    </address>
  </section>

  <section>
    <h2>Send Us a Message</h2>
    <ContactForm action="/api/lead" />
  </section>
</BaseLayout>
