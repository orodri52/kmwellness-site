---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import aetna from '../assets/images/insurance/aetna.png';
import alignmentHealth from '../assets/images/insurance/alignment-health.png';
import blueCrossBlueShield from '../assets/images/insurance/blue-cross-blue-shield.png';
import wellmed from '../assets/images/insurance/wellmed.png';
import cigna from '../assets/images/insurance/cigna.png';
import ambetter from '../assets/images/insurance/ambetter.jpg';
import humana from '../assets/images/insurance/humana.png';
import unitedhealthcare from '../assets/images/insurance/unitedhealthcare.png';

const seo = {
  title: 'Insurances We Accept | KM Wellness Center | El Paso, TX',
  description:
    'KM Wellness Center accepts Aetna, Alignment Health Plan, Blue Cross Blue Shield, WellMed, Cigna, Ambetter, Humana, and UnitedHealthcare.',
};

const insurers = [
  { name: 'Aetna', logo: aetna },
  { name: 'Alignment Health Plan', logo: alignmentHealth },
  { name: 'Blue Cross Blue Shield', logo: blueCrossBlueShield },
  { name: 'WellMed', logo: wellmed },
  { name: 'Cigna', logo: cigna },
  { name: 'Ambetter Health', logo: ambetter },
  { name: 'Humana', logo: humana },
  { name: 'UnitedHealthcare', logo: unitedhealthcare },
];
---
<BaseLayout {...seo}>
  <Breadcrumbs crumbs={[{ name: 'Home', href: '/' }, { name: 'About', href: '/about-us/' }, { name: 'Insurances we Accept', href: '/insurances-we-accept/' }]} />
  <h1>Insurances We Accept</h1>
  <p>
    KM Wellness Center works with most major PPO insurance plans, including the providers below.
  </p>
  <div class="insurer-logo-section">
    <ul class="insurer-grid">
      {insurers.map((i) => (
        <li>
          <Image src={i.logo} alt={`${i.name} insurance accepted at KM Wellness Center`} height={120} format="webp" quality={80} loading="lazy" decoding="async" />
        </li>
      ))}
    </ul>
  </div>
  <p class="provider-note">
    This is not a complete list of our accepted insurance providers. Additional provider logos will
    be added soon.
  </p>
  <p>
    Coverage varies by plan. <a href="/contact-us/">Contact us</a> and we'll help verify your benefits
    before you begin care.
  </p>
</BaseLayout>

<style>
  .insurer-logo-section {
    width: min(100%, 960px);
    margin: 1.5rem auto;
  }
  .insurer-grid {
    list-style: none;
    width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    align-items: center;
  }
  .insurer-grid li {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 0 0 210px;
    box-sizing: border-box;
    padding: 1rem;
  }
  .insurer-grid img {
    max-width: 100%;
    max-height: 60px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .provider-note {
    text-align: center;
    font-weight: 700;
  }
</style>
